{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://salary-extractor/schemas/llm_payload.schema.json",
  "title": "SalaryExtractorLLMPayload",
  "description": "Compact payload Design §14 — what the detector sends to an LLM reviewer.",
  "type": "object",
  "required": [
    "task",
    "jurisdiction",
    "country_region",
    "candidate_sets",
    "instructions"
  ],
  "additionalProperties": false,
  "properties": {
    "task": {
      "type": "string",
      "minLength": 1
    },
    "jurisdiction": {
      "type": "string"
    },
    "country_region": {
      "type": "string"
    },
    "analysis_id": {
      "type": "string"
    },
    "candidate_sets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/candidate"
      }
    },
    "near_misses": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/candidate"
      }
    },
    "applied_hints": {
      "$ref": "#/$defs/applied_hints"
    },
    "instructions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "candidate": {
      "type": "object",
      "required": [
        "id",
        "candidate_type",
        "confidence",
        "confidence_band",
        "transactions",
        "score_breakdown",
        "detected_pattern",
        "reasoning",
        "risks"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string"
        },
        "candidate_type": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "confidence_band": {
          "type": "string",
          "enum": [
            "high",
            "medium_high",
            "medium",
            "low",
            "very_low"
          ]
        },
        "transactions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/transaction_compact"
          }
        },
        "score_breakdown": {
          "$ref": "#/$defs/score_breakdown"
        },
        "detected_pattern": {
          "$ref": "#/$defs/detected_pattern"
        },
        "reasoning": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "merged_sources": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "anchor_in_cluster": {
          "type": "boolean"
        },
        "possible_employment_transition": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "near_miss_reason": {
          "type": "string",
          "enum": [
            "cap_overflow",
            "below_threshold"
          ]
        },
        "induced_pattern_signature": {
          "type": "string"
        },
        "amount_date_only": {
          "type": "boolean"
        }
      }
    },
    "transaction_compact": {
      "type": "object",
      "required": [
        "transaction_id",
        "date",
        "amount"
      ],
      "additionalProperties": false,
      "properties": {
        "transaction_id": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "amount": {
          "type": "number"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "score_breakdown": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "date": {
          "type": "number"
        },
        "description": {
          "type": "number"
        },
        "amount": {
          "type": "number"
        },
        "channel": {
          "type": "number"
        },
        "coverage": {
          "type": "number"
        },
        "context_bonus": {
          "type": "number"
        },
        "anchor_bonus": {
          "type": "number"
        },
        "salary_band_modifier": {
          "type": "number"
        },
        "negative_penalty": {
          "type": "number"
        },
        "final": {
          "type": "number"
        }
      }
    },
    "detected_pattern": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "frequency": {
          "type": "string"
        },
        "payday_model": {
          "type": "string"
        },
        "amount_model": {
          "type": "string"
        },
        "payment_channel": {
          "type": "string"
        },
        "possible_employer_tokens": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "coverage": {
          "type": "string"
        }
      }
    },
    "applied_hints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "anchor_count": {
          "type": "integer",
          "minimum": 0
        },
        "anchor_transaction_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "unmatched_hint_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "effective_monthly": {
          "type": [
            "number",
            "null"
          ]
        },
        "band_lower": {
          "type": [
            "number",
            "null"
          ]
        },
        "band_upper": {
          "type": [
            "number",
            "null"
          ]
        }
      }
    }
  }
}
