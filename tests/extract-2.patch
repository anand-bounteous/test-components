+  crops: TableCropEntry[];
+}
+
+export interface SolutionResult {
+  solution_name: string;
+  status: SolutionStatus;
+  skipped_reason?: string | null;
+  pages: PageResult[];
+  audit: AuditStep[];
+  timings: { total_ms: number; by_stage: Record<string, number> };
