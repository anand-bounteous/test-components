+    n_entities: number;
+    n_mocks: number;
+    entity_types?: Record<string, number>;
+    has_image: boolean;
+    error?: string | null;
+  };
+}
+
+export interface RedactionDiffSpan {
+  start: number;
+  end: number;
+  original: string;
+  mock: string;
+  entity_type: string;
