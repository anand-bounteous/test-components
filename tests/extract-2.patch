+                const tables = (sol.pages ?? []).reduce((n, p) => n + (p.tables?.length ?? 0), 0);
+                return (
+                  <tr key={sol.solution_name} style={{ borderTop: "1px solid var(--border)" }}>
+                    <td style={{ padding: "6px 8px" }}><code>{sol.solution_name}</code></td>
