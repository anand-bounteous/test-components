+            />
+            <label className="row" style={{ gap: 4, fontSize: 11 }}>
+              <input
+                type="checkbox"
+                checked={row.scope === "run"}
+                onChange={(e) =>
+                  onChangeRow(row.id, { scope: e.target.checked ? "run" : "doc" })
