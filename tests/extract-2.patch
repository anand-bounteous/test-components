+            <tbody>
+              {visibleLines.map((l) => {
+                const rowBg = l.changed ? "#fff8e1" : "transparent";
+                const leftBg = l.changed ? "#ffeef0" : rowBg;
+                const rightBg = l.changed ? "#e6ffec" : rowBg;
+                return (
+                  <tr key={l.index}>
+                    <td style={{ ...gutterStyle, background: leftBg }}>{l.index + 1}</td>
+                    <td style={{ ...cellStyle, background: leftBg }}>
